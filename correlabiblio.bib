	isbn = {978-0-12-811432-2},
	keywords = {Computational biology, Gene co-expression networks, Gene regulatory networks, Metabolic networks, Network analysis, Network medicine, Neuroscience, Protein-protein interactions, Signaling networks, Statistical inference},
	pages = {805-813},
	publisher = {Academic Press},
	title = {Network Inference and Reconstruction in Bioinformatics},
	url = {https://www.sciencedirect.com/science/article/pii/B9780128096338202902},
	year = {2019},
